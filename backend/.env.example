APP_NAME=OpportunityRadar
DEBUG=false

# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key
SUPABASE_JWT_SECRET=your_jwt_secret

# LLM (pick one or both)
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# Email
SENDGRID_API_KEY=your_sendgrid_key
FROM_EMAIL=hello@opportunityradar.com

# Redis
REDIS_URL=redis://redis:6379/0

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/opportunityradar

# Scraping
SCRAPER_INTERNSHALA_ENABLED=true
SCRAPER_LINKEDIN_ENABLED=true
SCRAPER_WELLFOUND_ENABLED=true
SCRAPER_INTERVAL_HOURS=6

# Digest
DIGEST_DAY=sunday
DIGEST_TIME=10:00

# Frontend
FRONTEND_URL=http://localhost:5173
