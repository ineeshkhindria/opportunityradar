APP_NAME=OpportunityRadar
DEBUG=false

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
# Local (Docker): postgresql+asyncpg://postgres:postgres@db:5432/opportunityradar
# Production:     postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/opportunityradar

# ──────────────────────────────────────────────
# Auth (JWT secret — change in production!)
# ──────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_JWT_SECRET=change-this-to-a-random-64-char-string

# ──────────────────────────────────────────────
# LLM Ranking (pick one)
# ──────────────────────────────────────────────
# Gemini (free tier, no credit card) — default
GEMINI_API_KEY=
# OpenAI (paid)
OPENAI_API_KEY=
# Anthropic (paid)
ANTHROPIC_API_KEY=
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash

# ──────────────────────────────────────────────
# Redis (for Celery background jobs)
# ──────────────────────────────────────────────
# Docker: redis://redis:6379/0
# Render: redis(s)://user:pass@host:port
REDIS_URL=redis://redis:6379/0

# ──────────────────────────────────────────────
# Scraping
# ──────────────────────────────────────────────
SCRAPER_INTERNSHALA_ENABLED=false
SCRAPER_LINKEDIN_ENABLED=true
SCRAPER_WELLFOUND_ENABLED=false
SCRAPER_INTERVAL_HOURS=6

# ──────────────────────────────────────────────
# Email (weekly digest)
# ──────────────────────────────────────────────
# Sign up at sendgrid.com (free tier: 100 emails/day)
SENDGRID_API_KEY=
FROM_EMAIL=hello@opportunityradar.com
DIGEST_DAY=sunday
DIGEST_TIME=10:00

# ──────────────────────────────────────────────
# Frontend URL (for CORS)
# ──────────────────────────────────────────────
# Local:   http://localhost:5173
# Vercel:  https://opportunityradar.vercel.app
FRONTEND_URL=http://localhost:5173
